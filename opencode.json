{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "instructions/pre-tool-announce.md",
    "instructions/github-pr-cli.md",
    "instructions/bash_tool.md"
  ],
  "plugin": [
    "file:///home/null/.config/opencode/plugin/autocontinue.ts",
    "file:///home/null/.config/opencode/plugin/terminal-bell.ts"
  ],
  "command": {
    "autocontinue": {
      "description": "Enable timed auto-continue",
      "template": " "
    }
  },
  "permission": {
    "websearch": "allow"
  },
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (dgx)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1",
        "timeout": 45000,
        "chunkTimeout": 15000
      },
      "models": {
        "qwen3": {
          "name": "Qwen3",
          "options": {
            "reasoning_format": "none",
            "reasoning": "off",
            "reasoning_budget_tokens": 0
          }
        }
      }
    },
    "vllm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "vLLM server",
      "options": {
        "baseURL": "http://127.0.0.1:8000/v1",
        "timeout": 45000,
        "chunkTimeout": 15000
      },
      "models": {
        "/model": {
          "name": "/model",
          "options": {
            "max_tokens": 4096
          }
          // e.g., "Qwen2‑7B", "Llama‑3‑8B", etc.
        }
      }
    }
  },
  "agent": {
    "research": {
      "steps": 6
    },
    "research-exec": {
      "steps": 4
    }
  }
}
